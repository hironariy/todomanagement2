# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to Git!

# Database Configuration
# For local development, use SQLite (DATABASE_TYPE=sqlite)
# For Azure/Production, use PostgreSQL (DATABASE_TYPE=postgresql)
DATABASE_TYPE=sqlite

# PostgreSQL Configuration (required when DATABASE_TYPE=postgresql)
POSTGRES_SERVER=your-postgres-server.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=tododb
POSTGRES_USER=your_user@your-postgres-server
# Leave POSTGRES_PASSWORD empty when using Entra ID authentication in Azure
# For local development with password auth, set it here:
POSTGRES_PASSWORD=

# Application Environment
ENVIRONMENT=development
